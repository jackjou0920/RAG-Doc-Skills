# Document RAG MCP Server — Environment Configuration
# Copy to .env and adjust as needed.

# Path to the ChromaDB persistent directory (created by the pdf-parser / pptx-parser skills)
CHROMA_DB_PATH=../chroma_db

# ChromaDB collection name (shared by PDF and PPTX ingestion)
CHROMA_COLLECTION=documents

# Server bind host/port
HOST=0.0.0.0
PORT=8011

# MCP endpoint path prefix -> http://HOST:PORT/{MCP_PATH}/mcp
MCP_PATH=rag